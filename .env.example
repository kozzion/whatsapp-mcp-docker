# Absolute host directory where the WhatsApp session + message database +
# downloaded media are stored (bind-mounted into the container). Copy this file
# to `.env` and set an absolute path. Examples:
#   macOS/Linux: /Users/you/data/whatsapp-mcp
#   Windows:     C:/data/whatsapp-mcp   (use forward slashes)
PATH_DIR_DATA_WHATSAPPMCP=/absolute/path/to/whatsapp-mcp-data
